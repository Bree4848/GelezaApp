@page "/upload"

<PageTitle>Geleza - Upload Resource</PageTitle>

<div class="container mt-4">
    <h3>Educator Dashboard</h3>
    <p>Upload new question papers, memorandums, or video links for your learners.</p>

    <div class="card p-4 shadow-sm">
        <div class="mb-3">
            <label class="form-label">Resource Title</label>
            <input type="text" class="form-control" placeholder="e.g. Mathematics P1 2025" />
        </div>
        
        <div class="mb-3">
            <label class="form-label">Grade</label>
            <select class="form-select">
                <option>Grade 10</option>
                <option>Grade 11</option>
                <option>Grade 12</option>
            </select>
        </div>

        <button class="btn btn-primary">Save Resource</button>
    </div>
</div>